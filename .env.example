# Minecraft server
MINECRAFT_VERSION=1.21.11
MINECRAFT_MEMORY=4G
MINECRAFT_MOTD=MVMP Friends Server
MINECRAFT_DIFFICULTY=normal
MINECRAFT_MAX_PLAYERS=20

# Discord bridge plugin
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/replace/replace

# Discord web app / future bot worker
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=
MVMP_WORLDS=main:DISCORD_CHANNEL_ID:Main World:Fallback world for messages without a [world] prefix
WEB_PORT=3000
